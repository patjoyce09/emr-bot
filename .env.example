# Service
PORT=4000
NODE_ENV=development
ARTIFACTS_ROOT=./artifacts
ARTIFACT_RETENTION_DAYS=30
SCREENSHOT_RETENTION_DAYS=7
KEEP_FAILURE_SCREENSHOTS=true
ARTIFACT_CLEANUP_INTERVAL_MS=3600000
JOB_STORE_PATH=./state/jobs.json
APP_VERSION=0.1.0
WORKER_POLL_INTERVAL_MS=3000
JOB_LEASE_TIMEOUT_MS=600000
JOB_HEARTBEAT_INTERVAL_MS=20000
JOB_MAX_ATTEMPTS=1

# Caller auth (configure at least one)
EMR_GATEWAY_BEARER_TOKEN=
# Optional per-tenant bearer mapping JSON, example:
# EMR_GATEWAY_BEARER_TENANT_MAP={"tenant-a":"token-a","tenant-b":"token-b"}
EMR_GATEWAY_BEARER_TENANT_MAP=
EMR_GATEWAY_HMAC_SECRET=
EMR_GATEWAY_HMAC_MAX_SKEW_SEC=300
EMR_GATEWAY_NONCE_TTL_SEC=300

# Optional tenant scope signature secret for x-tenant-id when auth token has no tenant claim
EMR_GATEWAY_TENANT_HEADER_SECRET=

# Admin-only operations
ENABLE_ADMIN_ENDPOINTS=false
EMR_GATEWAY_ADMIN_TOKEN=

# Optional tenant authorization allow-list (comma separated)
# ALLOWED_TENANTS=tenant-a,tenant-b
ALLOWED_TENANTS=

# WellSky endpoints
WELLSKY_BASE_URL=https://example-wellsky-instance.com
WELLSKY_LOGIN_PATH=/login
WELLSKY_REPORT_PATH=/reports/schedule
WELLSKY_HEADLESS=true
# Optional selector profile overrides
# JSON shape:
# {
#   "tenant-a": {
#     "default": {
#       "version": "tenant-a-v2",
#       "selectors": {
#         "reportReadyMarker": "form[data-tenant='a']"
#       }
#     }
#   }
# }
WELLSKY_SELECTOR_OVERRIDES_JSON=
WELLSKY_SELECTOR_OVERRIDES_PATH=

# Credentials (prefer tenant-specific keys)
# WELLSKY_USERNAME_<TENANT_ID>=username
# WELLSKY_PASSWORD_<TENANT_ID>=password
WELLSKY_USERNAME=
WELLSKY_PASSWORD=

# Optional JSON secret map for local development only.
# Example:
# SECRET_MANAGER_JSON={"wellsky/tenantA/username":"...","wellsky/tenantA/password":"..."}
SECRET_MANAGER_JSON=
